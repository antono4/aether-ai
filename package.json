{
  "name": "aether",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24.0.0", "pnpm": ">=10.10.0" },
  "scripts": {
    "dev": "pnpm --filter @aether/desktop dev",
    "dev:server": "pnpm --filter @aether/server dev",
    "dev:cli": "pnpm --filter @aether/cli dev",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev\"",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @aether/ai-core build && pnpm --filter @aether/shared-types build && pnpm --filter @aether/memory build",
    "build:rust": "cargo build --release --workspace",
    "start": "pnpm --filter @aether/server start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:rust": "cargo test --workspace",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:rs": "cargo fmt --all",
    "lint:rs": "cargo clippy --all-targets -- -D warnings",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo && cargo clean",
    "verify": "pnpm typecheck && cargo test --workspace"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.10.0"
}
